      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug"
    },
    {
      "name": "build-release",
      "configurePreset": "windows-release",
      "configuration": "Release"
    }
  ]
